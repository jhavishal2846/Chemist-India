# =============================================================================
# Chemist India — environment variable template
# -----------------------------------------------------------------------------
#  • For local dev: copy this file to `.env.local`, fill in real values.
#  • For Vercel deployment: paste each KEY=VALUE into the Vercel project's
#    Settings → Environment Variables. Do NOT commit the real values.
# =============================================================================

# --- SMTP credentials --------------------------------------------------------
# Common providers (host + port + how the user/pass fields work):
#   Provider              Host                                 Port  Notes
#   -------------------- ------------------------------------- ----  ------------------
#   Hotmail / Outlook    smtp-mail.outlook.com                 587   STARTTLS. Personal
#                                                                    accounts: Microsoft
#                                                                    disabled SMTP AUTH
#                                                                    in 2022 — likely
#                                                                    won't work.
#   Office 365 business  smtp.office365.com                    587   STARTTLS. Tenant
#                                                                    admin must enable
#                                                                    SmtpClientAuthentication.
#   Brevo (Sendinblue)   smtp-relay.brevo.com                  587   23-char SMTP key as PASS.
#   SendGrid             smtp.sendgrid.net                     587   USER is literal "apikey".
#   AWS SES              email-smtp.<region>.amazonaws.com     587   SMTP credentials only,
#                                                                    NOT IAM keys.
#   Resend               smtp.resend.com                       465   USER is literal "resend".
#   Mailtrap sandbox     sandbox.smtp.mailtrap.io              2525  Fake inbox, no delivery.
#   Mailtrap live        live.smtp.mailtrap.io                 587   Real delivery.

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password-or-smtp-key

# Outbound "From:" header. With Office 365 / Outlook this MUST be the same
# mailbox as SMTP_USER (cross-mailbox From triggers SendAsDenied). With
# SES/SendGrid/Resend the domain must be verified.
MAIL_FROM="Chemist India <you@example.com>"

# Inbox that receives internal lead/contact notifications.
MAIL_TO_INTERNAL=you@example.com

# --- Diagnostics -------------------------------------------------------------
# Set to "1" to expose /api/email-health in production. Leave unset/empty in
# production unless actively debugging.
# EMAIL_HEALTH_ENABLED=
